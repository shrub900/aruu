#!/bin/sh
# mkbox - build aruu-box, the aruu multi-call binary
#
# expects CC CPPFLAGS CFLAGS LDFLAGS LDLIBS OBJCOPY YACC from the environment
# defaults match config.mk but can be overridden
#
# run from the source root (the Makefile does this automatically)

set -e

: "${CC:=cc}"
: "${CPPFLAGS:=-Ishared -D_DEFAULT_SOURCE -D_GNU_SOURCE -D_NETBSD_SOURCE -D_BSD_SOURCE -D_XOPEN_SOURCE=700 -D_FILE_OFFSET_BITS=64}"
: "${CFLAGS:=-std=c99 -Wall -Wextra -pedantic}"
: "${LDFLAGS:=}"
: "${LDLIBS:=-lcrypt -lresolv}"
: "${OBJCOPY:=objcopy}"
: "${YACC:=yacc}"

ROOT=$(CDPATH= cd "$(dirname "$0")/.." && pwd)
BDIR="${ROOT}/.box"
BOX="${ROOT}/aruu-box"
LIBREDLINE="${ROOT}/shared/libredline/libredline.a"
LIBUTIL="${ROOT}/shared/libutil/libutil.a"
LIBUTF="${ROOT}/shared/libutf/libutf.a"

die() {
	printf 'mkbox: %s\n' "$*" >&2
	exit 1
}

# Clean up build directory on exit or signal termination
trap 'rm -rf "${BDIR}"' EXIT INT QUIT TERM

[ -f "${LIBREDLINE}" ] || die "libredline.a not found; run 'make' first"
[ -f "${LIBUTIL}" ] || die "libutil.a not found; run 'make' first"
[ -f "${LIBUTF}" ]  || die "libutf.a not found; run 'make' first"

[ -f "${ROOT}/cmd/posix/getconf.h" ] || {
	printf 'mkbox: generating getconf.h\n'
	"${ROOT}/scripts/getconf.sh" > "${ROOT}/cmd/posix/getconf.h" ||
		die "scripts/getconf.sh failed"
}

rm -rf "${BDIR}"
mkdir -p "${BDIR}"

OBJS=""
DECL_F="${BDIR}/decls.inc"
: > "${DECL_F}"
for _c in posix linux net pseudo xsi extra; do
	: > "${BDIR}/entries_${_c}.inc"
done
unset _c

alias_entry() {
	printf '\t{ "%s", %s_main, "%s" },\n' "$1" "$2" "$3" \
		>> "${BDIR}/entries_${3}.inc"
}

compile_tool() {
	src="$1"
	name="$2"
	fn="$3"
	catg="$4"
	extra="${5:-}"
	out="${BDIR}/${fn}.o"
	symf="${BDIR}/${fn}.syms"

	printf 'mkbox: cc %s\n' "${name}"
	eval "${CC} ${CPPFLAGS} ${extra} ${CFLAGS} -c \"\$src\" -o \"\$out\"" ||
		die "compile failed: ${src}"
	printf 'main %s_main\n' "${fn}" > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${out}" ||
		die "objcopy failed: ${name}"
	${OBJCOPY} --keep-global-symbol="${fn}_main" "${out}" ||
		die "objcopy localize failed: ${name}"
	rm -f "${symf}"
	OBJS="${OBJS} ${out}"
	printf 'int %s_main(int, char **);\n' "${fn}" >> "${DECL_F}"
	printf '\t{ "%s", %s_main, "%s" },\n' "${name}" "${fn}" "${catg}" \
		>> "${BDIR}/entries_${catg}.inc"
}

compile_make() {
	mdir="${ROOT}/cmd/posix/make"
	symf="${BDIR}/make.syms"
	printf 'mkbox: cc make (multi)\n'
	make_objs=""
	for s in defaults parser posix rules; do
		out="${BDIR}/make_${s}.o"
		eval "${CC} ${CPPFLAGS} ${CFLAGS} -I\"\$mdir\" -c \"\$mdir/\$s.c\" -o \"\$out\"" ||
			die "compile failed: make/${s}.c"
		make_objs="${make_objs} ${out}"
	done
	out_main="${BDIR}/make_main.o"
	eval "${CC} ${CPPFLAGS} ${CFLAGS} -I\"\$mdir\" -c \"\$mdir/main.c\" -o \"\${out_main}\"" ||
		die "compile failed: make/main.c"
	make_objs="${make_objs} ${out_main}"

	# Combined incremental link to resolve internal symbols cleanly
	combined="${BDIR}/make_combined.o"
	${LD:-ld} -r -o "${combined}" ${make_objs} ||
		die "ld -r failed: make"

	printf 'main make_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: make"
	${OBJCOPY} --keep-global-symbol=make_main "${combined}" ||
		die "objcopy localize failed: make"
	rm -f "${symf}" ${make_objs}

	OBJS="${OBJS} ${combined}"
	printf 'int make_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "make", make_main, "posix" },\n' >> "${BDIR}/entries_posix.inc"
}

compile_diff() {
	ddir="${ROOT}/cmd/posix/diff"
	symf="${BDIR}/diff.syms"
	diff_objs=""

	printf 'mkbox: cc diff (multi)\n'
	for s in diff diffdir diffreg pr xmalloc; do
		out="${BDIR}/diff_${s}.o"
		eval "${CC} ${CPPFLAGS} -I\"\$ddir\" ${CFLAGS} -c \"\$ddir/\$s.c\" -o \"\$out\"" ||
			die "compile failed: diff/${s}.c"
		diff_objs="${diff_objs} ${out}"
	done

	combined="${BDIR}/diff_combined.o"
	${LD:-ld} -r -o "${combined}" ${diff_objs} ||
		die "ld -r failed: diff"

	printf 'main diff_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: diff"
	${OBJCOPY} --keep-global-symbol=diff_main "${combined}" ||
		die "objcopy localize failed: diff"
	rm -f "${symf}" ${diff_objs}

	OBJS="${OBJS} ${combined}"
	LDLIBS="${LDLIBS} -lm"
	printf 'int diff_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "diff", diff_main, "posix" },\n' >> "${BDIR}/entries_posix.inc"
}

compile_patch() {
	pdir="${ROOT}/cmd/posix/patch"
	symf="${BDIR}/patch.syms"
	patch_objs=""

	printf 'mkbox: cc patch (multi)\n'
	for s in patch pch inp util backupfile mkpath; do
		out="${BDIR}/patch_${s}.o"
		eval "${CC} ${CPPFLAGS} -I\"\$pdir\" ${CFLAGS} -c \"\$pdir/\$s.c\" -o \"\$out\"" ||
			die "compile failed: patch/${s}.c"
		patch_objs="${patch_objs} ${out}"
	done

	combined="${BDIR}/patch_combined.o"
	${LD:-ld} -r -o "${combined}" ${patch_objs} ||
		die "ld -r failed: patch"

	printf 'main patch_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: patch"
	${OBJCOPY} --keep-global-symbol=patch_main "${combined}" ||
		die "objcopy localize failed: patch"
	rm -f "${symf}" ${patch_objs}

	OBJS="${OBJS} ${combined}"
	printf 'int patch_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "patch", patch_main, "posix" },\n' >> "${BDIR}/entries_posix.inc"
}

compile_diff3() {
	ddir="${ROOT}/cmd/extra/diff3"
	pdir="${ROOT}/cmd/posix/diff"
	symf="${BDIR}/diff3.syms"
	diff3_objs=""

	printf 'mkbox: cc diff3 (multi)\n'
	for s in diff3; do
		out="${BDIR}/diff3_${s}.o"
		eval "${CC} ${CPPFLAGS} -I\"\$pdir\" ${CFLAGS} -c \"\$ddir/\$s.c\" -o \"\$out\"" ||
			die "compile failed: diff3/${s}.c"
		diff3_objs="${diff3_objs} ${out}"
	done
	out="${BDIR}/diff3_xmalloc.o"
	eval "${CC} ${CPPFLAGS} -I\"\$pdir\" ${CFLAGS} -c \"\$pdir/xmalloc.c\" -o \"\$out\"" ||
		die "compile failed: diff/xmalloc.c"
	diff3_objs="${diff3_objs} ${out}"

	combined="${BDIR}/diff3_combined.o"
	${LD:-ld} -r -o "${combined}" ${diff3_objs} ||
		die "ld -r failed: diff3"

	printf 'main diff3_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: diff3"
	${OBJCOPY} --keep-global-symbol=diff3_main "${combined}" ||
		die "objcopy localize failed: diff3"
	rm -f "${symf}" ${diff3_objs}

	OBJS="${OBJS} ${combined}"
	printf 'int diff3_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "diff3", diff3_main, "extra" },\n' >> "${BDIR}/entries_extra.inc"
}

compile_awk() {
	adir="${ROOT}/cmd/posix/awk"
	symf="${BDIR}/awk.syms"
	awk_objs=""

	printf 'mkbox: yacc awk/awkgram.y\n'
	${YACC} -d -o "${adir}/awkgram.tab.c" "${adir}/awkgram.y" ||
		die "yacc failed: awk/awkgram.y"

	# maketab is a host code-generator, only needs CFLAGS, no CPPFLAGS
	printf 'mkbox: cc awk/maketab\n'
	${CC} ${CFLAGS} -o "${BDIR}/awk_maketab" "${adir}/maketab.c" ||
		die "compile failed: awk/maketab.c"

	printf 'mkbox: gen awk/proctab.c\n'
	"${BDIR}/awk_maketab" "${adir}/awkgram.tab.h" > "${adir}/proctab.c" ||
		die "maketab failed"

	for s in b main parse proctab tran lib run lex math; do
		out="${BDIR}/awk_${s}.o"
		eval "${CC} ${CPPFLAGS} -I\"\$adir\" ${CFLAGS} -c \"\$adir/${s}.c\" -o \"\$out\"" ||
			die "compile failed: awk/${s}.c"
		awk_objs="${awk_objs} ${out}"
	done
	out="${BDIR}/awk_awkgram.tab.o"
	eval "${CC} ${CPPFLAGS} -I\"\$adir\" ${CFLAGS} -c \"\$adir/awkgram.tab.c\" -o \"\$out\"" ||
		die "compile failed: awk/awkgram.tab.c"
	awk_objs="${awk_objs} ${out}"

	combined="${BDIR}/awk_combined.o"
	${LD:-ld} -r -o "${combined}" ${awk_objs} ||
		die "ld -r failed: awk"

	printf 'main awk_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: awk"
	${OBJCOPY} --keep-global-symbol=awk_main "${combined}" ||
		die "objcopy localize failed: awk"
	rm -f "${symf}" ${awk_objs}

	OBJS="${OBJS} ${combined}"
	LDLIBS="${LDLIBS} -lm"
	printf 'int awk_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "awk", awk_main, "posix" },\n' >> "${BDIR}/entries_posix.inc"
}

compile_sh() {
	sdir="${ROOT}/cmd/posix/sh"
	symf="${BDIR}/sh.syms"
	sh_objs=""

	# mknodes and mksyntax are host code-generators, not part of the shell
	printf 'mkbox: cc sh/mknodes\n'
	${CC} ${CFLAGS} -o "${BDIR}/sh_mknodes" "${sdir}/mknodes.c" ||
		die "compile failed: sh/mknodes.c"

	printf 'mkbox: cc sh/mksyntax\n'
	${CC} ${CPPFLAGS} -I"${sdir}" ${CFLAGS} -o "${BDIR}/sh_mksyntax" "${sdir}/mksyntax.c" ||
		die "compile failed: sh/mksyntax.c"

	printf 'mkbox: gen sh/nodes.{c,h}\n'
	(cd "${sdir}" && "${BDIR}/sh_mknodes" nodetypes nodes.c.pat) ||
		die "mknodes failed"

	printf 'mkbox: gen sh/syntax.{c,h}\n'
	(cd "${sdir}" && "${BDIR}/sh_mksyntax") ||
		die "mksyntax failed"

	printf 'mkbox: gen sh/builtins.{c,h}\n'
	(cd "${sdir}" && sh mkbuiltins .) ||
		die "mkbuiltins failed"

	printf 'mkbox: gen sh/token.h\n'
	(cd "${sdir}" && sh mktokens) ||
		die "mktokens failed"

	for s in alias arith_yacc arith_yylex cd echo error eval exec \
	          expand lineedit input jobs kill mail main memalloc \
	          miscbltin mystring options output parser printf redir \
	          show test trap var builtins nodes syntax; do
		out="${BDIR}/sh_${s}.o"
		eval "${CC} ${CPPFLAGS} -DSHELL -I\"\$sdir\" ${CFLAGS} -c \"\$sdir/${s}.c\" -o \"\$out\"" ||
			die "compile failed: sh/${s}.c"
		sh_objs="${sh_objs} ${out}"
	done

	combined="${BDIR}/sh_combined.o"
	${LD:-ld} -r -o "${combined}" ${sh_objs} ||
		die "ld -r failed: sh"

	printf 'main sh_main\n' > "${symf}"
	${OBJCOPY} --redefine-syms="${symf}" "${combined}" ||
		die "objcopy failed: sh"
	${OBJCOPY} --keep-global-symbol=sh_main "${combined}" ||
		die "objcopy localize failed: sh"
	rm -f "${symf}" ${sh_objs}

	OBJS="${OBJS} ${combined}"
	printf 'int sh_main(int, char **);\n' >> "${DECL_F}"
	printf '\t{ "sh", sh_main, "posix" },\n' >> "${BDIR}/entries_posix.inc"
}

process_dir() {
	dir="$1"
	catg="$2"
	extra="${3:-}"
	for src in "${dir}"/*.c; do
		[ -f "${src}" ] || continue
		name=${src##*/}
		name=${name%.c}
		fn=$(printf '%s' "${name}" | tr '.-' '__')
		compile_tool "${src}" "${name}" "${fn}" "${catg}" "${extra}"
		if [ "${name}" = "test" ]; then
			alias_entry "[" "test" "${catg}"
		fi
		if [ "${name}" = "xinstall" ]; then
			alias_entry "install" "xinstall" "${catg}"
		fi
	done
}

process_dir "${ROOT}/cmd/posix" "posix"
compile_diff
compile_patch
compile_awk
compile_sh
compile_make
process_dir "${ROOT}/cmd/linux" "linux"
process_dir "${ROOT}/cmd/net" "net"
process_dir "${ROOT}/cmd/pseudo" "pseudo"
process_dir "${ROOT}/cmd/xsi" "xsi"
process_dir "${ROOT}/cmd/extra" "extra"
compile_diff3

DISP="${BDIR}/aruu-box.c"
printf 'mkbox: generating dispatch\n'

cat > "${DISP}" << 'DISPATCH_HEAD'
/* This software is released into the public domain, or
   registered under the ISC License, see ./LICENSE for details
   2026 xplshn [anto@xplshn.com.ar](mailto:anto@xplshn.com.ar) */

/* routes argv[0] to the appropriate tool main */
#include "util.h"

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

extern char *argv0;

DISPATCH_HEAD

cat "${DECL_F}" >> "${DISP}"

cat >> "${DISP}" << 'DISPATCH_STRUCT'

struct Cmd {
	const char *name;
	int (*fn)(int, char **);
	const char *cat;
};

static struct Cmd cmds[] = {
DISPATCH_STRUCT

# sort each category alphabetically by tool name at build time;
# entries have the form: \t{ "name", fn_main, "cat" },
# splitting on " makes field 2 the tool name
for _c in posix linux net pseudo xsi extra; do
	sort -t'"' -k2,2 "${BDIR}/entries_${_c}.inc"
done >> "${DISP}"
unset _c

cat >> "${DISP}" << 'DISPATCH_TAIL'
	{ NULL, NULL, NULL }
};

static void
usage(void)
{
	struct Cmd *c;
	const char *last;
	int col;

	last = NULL;
	col = 0;
	fprintf(stderr, "usage: %s [-i path] [command [args...]]\n", argv0);
	for (c = cmds; c->name; c++) {
		if (!last || strcmp(c->cat, last) != 0) {
			if (last)
				fprintf(stderr, "\n\n");
			last = c->cat;
			fprintf(stderr, "%s:\n", last);
			col = 0;
		}
		if (col == 0) {
			fprintf(stderr, "\t%s", c->name);
			col = 8 + strlen(c->name);
		} else if (col + 2 + strlen(c->name) >= 78) {
			fprintf(stderr, ",\n\t%s", c->name);
			col = 8 + strlen(c->name);
		} else {
			fprintf(stderr, ", %s", c->name);
			col += 2 + strlen(c->name);
		}
	}
	if (last)
		fputc('\n', stderr);
	exit(1);
}

static void
x_install(const char *path)
{
	struct Cmd *c;
	char buf[4096];
	int r;

	for (c = cmds; c->name; c++) {
		r = snprintf(buf, sizeof buf, "%s/%s", path, c->name);
		if (r < 0 || r >= (int)sizeof buf)
			eprintf("install: '%s/%s': path too long\n", path, c->name);
		remove(buf);
		if (symlink("aruu-box", buf) < 0)
			eprintf("install: symlink '%s':", buf);
	}
}

int
main(int argc, char *argv[])
{
	struct Cmd *c;
	char *s;

	argv0 = argv[0];

	s = strrchr(argv[0], '/');
	if (s)
		s++;
	else
		s = argv[0];

	if (strcmp(s, "aruu-box") == 0) {
		if (argc < 2)
			usage();
		argc--;
		argv++;
		if (strcmp(argv[0], "-i") == 0) {
			if (argc < 2)
				eprintf("usage: aruu-box -i path\n");
			x_install(argv[1]);
			return 0;
		}
		s = strrchr(argv[0], '/');
		if (s)
			s++;
		else
			s = argv[0];
	}
	for (c = cmds; c->name; c++) {
		if (strcmp(c->name, s) == 0) {
			argv0 = (char *)c->name;
			argv[0] = (char *)c->name;
			return c->fn(argc, argv);
		}
	}
	enprintf(127, "%s: not found\n", s);
	return 1;
}
DISPATCH_TAIL

printf 'mkbox: cc dispatch\n'
eval "${CC} ${CPPFLAGS} ${CFLAGS} -c \"\$DISP\" -o \"\${BDIR}/aruu-box.o\"" ||
	die "compile failed: dispatch"
OBJS="${OBJS} ${BDIR}/aruu-box.o"

printf 'mkbox: ld aruu-box\n'
eval "${CC} ${LDFLAGS} -o \"\$BOX\" \$OBJS \"\$LIBREDLINE\" \"\$LIBUTIL\" \"\$LIBUTF\" \${LDLIBS}" ||
	die "link failed"

printf 'mkbox: done => %s\n' "${BOX}"
